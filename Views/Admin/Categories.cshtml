@model IEnumerable<AutoSalonGrida.Models.Category>
@{ ViewData["Title"] = "Manage Categories"; }
<h1>Manage Categories</h1>
<form method="post" asp-action="AddCategory" class="d-flex gap-2 mb-3">
    <input name="name" class="form-control" placeholder="Новая категория" />
    <button class="btn btn-primary">Add</button>
</form>
<ul class="list-group">
@foreach (var c in Model)
{
    <li class="list-group-item bg-transparent text-light">@c.Name</li>
}
</ul>
