@model IEnumerable<AutoSalonGrida.Models.User>
@{
    ViewData["Title"] = "Общая таблица пользователей";
}

<h2 class="mb-3">Общая таблица</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-12 col-md-3">
        <input name="search" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Поиск по имени/логину" />
    </div>
    <div class="col-6 col-md-2">
        <input name="minAge" value="@ViewData["CurrentMinAge"]" type="number" class="form-control" placeholder="Возраст от" />
    </div>
    <div class="col-6 col-md-2">
        <input name="maxAge" value="@ViewData["CurrentMaxAge"]" type="number" class="form-control" placeholder="Возраст до" />
    </div>
    <div class="col-12 col-md-3">
        <select name="roleId" asp-items="ViewBag.RoleId" class="form-select">
            <option value="">Все роли</option>
        </select>
    </div>
    <div class="col-12 col-md-2 d-grid">
        <button class="btn btn-primary">Применить</button>
    </div>
</form>

@if (User.IsInRole("Администратор"))
{
    <p><a asp-action="Create" class="btn btn-success">Добавить запись</a></p>
}

<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th><a asp-action="Index" asp-route-sortOrder="@ViewData["NameSort"]">Имя</a></th>
            <th><a asp-action="Index" asp-route-sortOrder="@ViewData["AgeSort"]">Возраст</a></th>
            <th>Логин</th>
            <th><a asp-action="Index" asp-route-sortOrder="@ViewData["RoleSort"]">Роль</a></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Name</td>
            <td>@item.Age</td>
            <td>@item.Login</td>
            <td>@item.Role?.Name</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.IdUser">Просмотр</a>
                @if (User.IsInRole("Администратор"))
                {
                    <span>|</span> <a asp-action="Edit" asp-route-id="@item.IdUser">Редактировать</a>
                    <span>|</span> <a asp-action="Delete" asp-route-id="@item.IdUser">Удалить</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
</div>
