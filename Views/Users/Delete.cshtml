@model AutoSalonGrida.Models.User
@{
    ViewData["Title"] = "Удаление записи";
}

<h2>Удаление записи</h2>
<div class="alert alert-warning">Вы действительно хотите удалить запись?</div>
<dl class="row">
    <dt class="col-sm-3">Имя</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Логин</dt>
    <dd class="col-sm-9">@Model.Login</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="IdUser" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>
